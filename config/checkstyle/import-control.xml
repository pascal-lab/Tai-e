<?xml version="1.0"?>
<!DOCTYPE import-control PUBLIC "-//Checkstyle//DTD ImportControl Configuration 1.4//EN"
        "https://checkstyle.org/dtds/import_control_1_4.dtd">
<import-control pkg="pascal.taie">

    <!-- prefer pascal.taie.util.collection.Maps -->
    <disallow class="java.util.concurrent.ConcurrentHashMap"/>
    <disallow class="java.util.HashMap"/>
    <disallow class="java.util.LinkedHashMap"/>
    <disallow class="java.util.TreeMap"/>

    <!-- prefer pascal.taie.util.collection.Sets -->
    <disallow class="java.util.concurrent.CopyOnWriteArraySet"/>
    <disallow class="java.util.HashSet"/>
    <disallow class="java.util.LinkedHashSet"/>
    <disallow class="java.util.TreeSet"/>

    <!-- prefer java.nio.file.Path -->
    <disallow class="java.nio.file.Paths"/>

    <!-- Use SLF4J facade; direct Log4j2 imports are only allowed in logger configuration. -->
    <disallow pkg="org.apache.logging.log4j"/>

    <allow pkg=".*" regex="true"/>

    <subpackage name="util.collection">
        <allow pkg=".*" regex="true"/>
    </subpackage>

</import-control>
